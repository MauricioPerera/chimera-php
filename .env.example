# LLM Provider: workers-ai or openrouter
CHIMERA_LLM_PROVIDER=workers-ai
CHIMERA_LLM_MODEL=@cf/ibm-granite/granite-4.0-h-micro

# Cloudflare Workers AI
CF_ACCOUNT_ID=
CF_API_TOKEN=

# OpenRouter (optional)
OPENROUTER_API_KEY=

# Agent
CHIMERA_MAX_ITERATIONS=25
CHIMERA_DATA_DIR=./data
CHIMERA_LOG_LEVEL=info

# Telegram gateway (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
