{
    "name": "mauricioperera/chimera-php",
    "description": "Self-improving autonomous AI agent for PHP \u2014 multi-provider, persistent memory, learning loop",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "ai",
        "agent",
        "chimera",
        "autonomous",
        "self-improving",
        "llm",
        "tools",
        "memory"
    ],
    "require": {
        "php": ">=8.1",
        "mauricioperera/php-vector-store": "*",
        "mauricioperera/php-agent-memory": "*",
        "mauricioperera/php-agent-shell": "*",
        "mauricioperera/php-a2e": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "ChimeraPHP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ChimeraPHP\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/chimera"
    ],
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}